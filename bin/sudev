#!/usr/bin/env bash

SESSION="startup-$(basename "$PWD" | tr '/.@:' '_')"
PROJECT="$PWD"


if tmux has-session -t "$SESSION" 2>/dev/null; then
    exec tmux attach -t "$SESSION"
fi


tmux new-session -d -s "$SESSION" -c "$PROJECT"

# Extracting left pane id 
LEFT_PANE=$(tmux display-message -p -t "$SESSION":0.0 '#{pane_id}')
# Left pane sending keys for initiating: Neovim
tmux send-keys -t "$LEFT_PANE" 'nvim .' C-m

# Creating right pane
RIGHT_PANE=$(tmux split-window -h -p 30 -t "$LEFT_PANE" -P -F '#{pane_id}')

# Right pane sending keys for initiaiting: Claude
tmux send-keys -t "$RIGHT_PANE" "claude" C-m

# Creating bottom-left pane
BOTTOM_LEFT_PANE=$(tmux split-window -v -p 25 -t "$LEFT_PANE" -P -F '#{pane_id}')

# Focus editor pane
tmux select-pane -t "$LEFT_PANE"

exec tmux attach -t "$SESSION"
